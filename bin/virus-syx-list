#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/virus_ti/cli"

bin_name = File.basename($PROGRAM_NAME)
path = VirusTi::CLI.read_path!(ARGV, bin_name)

arrangement = VirusTi::List.arrangement(path)

if arrangement
  puts "Arrangement: #{arrangement.name || "(unnamed)"}"
  puts "Multi: bank 0x#{arrangement.multi.bank_byte.to_s(16)}  slot 0x#{arrangement.multi.slot_byte.to_s(16)}"
  puts
  puts "Parts (#{arrangement.parts.size}):"
  arrangement.parts.each do |part|
    checksum = part.single.checksum_valid? ? "ok" : "INVALID"
    puts format(
      "  %3d  %-8s  %-20s  checksum: %s",
      part.number,
      part.label,
      part.name || "(unnamed)",
      checksum
    )
  end
  exit 0
end

singles = VirusTi::List.singles(path)
multis = VirusTi::List.multis(path)

if singles.empty? && multis.empty?
  warn "No Single, Multi, or Arrangement dumps found in #{path}"
  exit 1
end

unless singles.empty?
  puts "Singles (#{singles.size}):"
  singles.each_with_index do |single, index|
    checksum = single.checksum_valid? ? "ok" : "INVALID"
    puts format(
      "  %3d  %-12s  %-18s  %-20s  checksum: %s",
      index + 1,
      single.bank_label,
      single.slot_label,
      single.name || "(unnamed)",
      checksum
    )
  end
end

unless multis.empty?
  puts unless singles.empty?
  puts "Multis (#{multis.size}):"
  multis.each_with_index do |multi, index|
    puts format(
      "  %3d  bank 0x%02X  slot 0x%02X  %-20s",
      index + 1,
      multi.bank_byte,
      multi.slot_byte,
      multi.name || "(unnamed)"
    )
  end
end
