#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/virus_ti/cli"

bin_name = File.basename($PROGRAM_NAME)
path = VirusTi::CLI.read_path!(ARGV, bin_name)

summary = VirusTi::Scan.summarize(path)

puts "File: #{summary[:path]}"
puts "Messages: #{summary[:message_count]}"
puts "Virus TI: #{summary[:virus_ti]}"
puts "Arrangements: #{summary[:arrangements]}"
puts "Single dumps: #{summary[:singles]}"
puts "Multi dumps: #{summary[:multis]}"

if summary[:arrangement]
  arrangement = VirusTi::List.arrangement(path)
  puts
  puts "Arrangement: #{arrangement.name || "(unnamed)"} (#{arrangement.parts.size} parts)"
end

return if summary[:commands].empty?

puts
puts "Commands:"
summary[:commands].sort.each do |command, count|
  label = case command
          when VirusTi::Sysex::CMD_SINGLE_DUMP then "Single Dump (0x10)"
          when VirusTi::Sysex::CMD_MULTI_DUMP then "Multi Dump (0x11)"
          else format("0x%02X", command)
          end
  puts "  #{label}: #{count}"
end
